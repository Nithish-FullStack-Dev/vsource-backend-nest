// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  counselor
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(counselor)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id String @id @default(uuid())

  studentName  String?
  mobileNumber String?
  emailId      String?
  place        String?
  passport     String?

  tenthPercentage    Float?
  tenthYearOfPassing Int?

  twelfthPercentage    Float?
  twelfthYearOfPassing Int?

  bachelorsCourse         String?
  bachelorsUniversityName String?

  bachelorsPercentage    Float?
  bachelorsYearOfPassing Int?

  backlogs Int?

  workExperience String?

  preferredCountry String?
  preferredIntake  String?
  preferredCourse  String?

  greGmatScore           Float?
  quantitativeScore      Float?
  verbalScore            Float?
  analyticalWritingScore Float?

  englishTestType String? // IELTS / TOEFL / DUOLINGO
  listeningScore  Float?
  writingScore    Float?
  readingScore    Float?
  speakingScore   Float?

  gapsIfAny String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
